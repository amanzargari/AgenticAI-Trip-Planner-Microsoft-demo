# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=google/gemini-2.0-flash

# ── Google APIs ───────────────────────────────────────────────────────────────
# Google Maps Platform key – used for Places API (text search, nearby search)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Agent service URLs ────────────────────────────────────────────────────────
# When running via Docker Compose use service-name hostnames (defaults below).
# For local dev outside Docker override with http://localhost:800X
AGENT1_URL=http://agent1:8001
AGENT2_URL=http://agent2:8002
AGENT3_URL=http://agent3:8003
AGENT4_URL=http://agent4:8004
ORCHESTRATOR_URL=http://orchestrator:8000
